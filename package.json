{
  "name": "ozeki-reading-bridge-foundation",
  "version": "1.0.0",
  "description": "Ozeki Reading Bridge Foundation full-stack webapp",
  "main": "index.js",
  "scripts": {
    "prebuild": "node -e \"console.log('Building ORBF...')\"",
    "test": "npm run test:all",
    "test:all": "node scripts/run-test-suite.mjs auto",
    "test:postgres": "node scripts/run-test-suite.mjs postgres",
    "test:privacy": "tsx --test src/tests/public-impact-privacy.test.ts src/tests/report-geo-cascade.test.ts src/tests/graduation-eligibility.test.ts src/tests/google-oauth-domain.test.ts",
    "test:school-first": "tsx --test src/tests/school-first-participants.test.ts",
    "test:finance": "tsx --test src/tests/finance-module.test.ts src/tests/finance-email-routing.test.ts src/tests/finance-lifecycle.test.ts",
    "test:payments": "tsx --test src/tests/pesapal-payment-flows.test.ts",
    "dev": "next dev",
    "clean:next": "node -e \"require('node:fs').rmSync('.next',{ recursive: true, force: true })\"",
    "dev:clean": "npm run clean:next && next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "prestart": "node -e \"console.log('Starting ORBF...')\"",
    "start": "npm run start:standalone",
    "start:standalone": "node scripts/start-standalone.mjs",
    "start:next": "next start",
    "lint": "eslint .",
    "deploy:check": "node scripts/deploy-readiness-check.mjs",
    "deploy:check:strict": "node scripts/deploy-readiness-check.mjs --strict",
    "ci:verify": "npm run lint && npm run test:all && npm run build",
    "ci:verify:strict": "npm run deploy:check:strict && npm run lint && npm run test:postgres && npm run build",
    "build:aws": "npm run postgres:bootstrap && npm run lint && npm run typecheck && npm run build",
    "deploy:ready": "npm run ci:verify:strict",
    "generate:pdf-sample": "tsx scripts/generate-pdf-sample.ts",
    "postgres:bootstrap": "tsx scripts/postgres-bootstrap.ts",
    "google:auth:url": "tsx scripts/google-workspace-oauth.ts url",
    "google:auth:exchange": "tsx scripts/google-workspace-oauth.ts exchange",
    "google:status": "tsx scripts/google-workspace-diagnostics.ts",
    "gsc:ping": "tsx scripts/gsc.ts ping",
    "gsc:list": "tsx scripts/gsc.ts list",
    "gsc:inspect": "tsx scripts/gsc.ts inspect",
    "gsc:analytics": "tsx scripts/gsc.ts analytics",
    "gsc:sync": "tsx scripts/gsc.ts sync"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/O-Mario88/Ozeki-reading-Bridge-Foundation.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <25"
  },
  "bugs": {
    "url": "https://github.com/O-Mario88/Ozeki-reading-Bridge-Foundation/issues"
  },
  "homepage": "https://github.com/O-Mario88/Ozeki-reading-Bridge-Foundation#readme",
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@tanstack/react-query": "^5.90.21",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-text-align": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "argon2": "^0.44.0",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "exceljs": "^4.4.0",
    "exifr": "^7.1.3",
    "framer-motion": "^12.35.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "nodemailer": "^8.0.2",
    "openai": "^6.25.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "puppeteer": "^24.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-quill-new": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.12",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.55.0",
    "wtfnode": "^0.10.1"
  },
  "overrides": {
    "inflight": "lru-cache@10",
    "rimraf": "^5.0.0",
    "glob": "^11.0.0"
  }
}
