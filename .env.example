# -----------------------------
# Frontend (Next.js)
# -----------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------
# Backend (Django)
# -----------------------------
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Kampala
DJANGO_LOG_LEVEL=INFO

# PostgreSQL only (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ozeki
DB_SSL_REQUIRE=false

# CORS/CSRF for frontend-backend split
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# Optional async jobs
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AWS S3 storage (optional in dev; required for production media/static strategy)
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Migration helper
SQLITE_SOURCE_PATH=./data/app.db
