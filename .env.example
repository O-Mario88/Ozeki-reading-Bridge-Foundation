# -----------------------------
# Core application
# -----------------------------
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
PUBLIC_SITE_HOST=localhost:3000
ADMIN_PORTAL_HOST=admin.localhost:3000
APP_DATA_DIR=./data

# -----------------------------
# PostgreSQL backend
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ozeki
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
LOG_ACTIVE_DB=true

# -----------------------------
# Portal authentication/security
# -----------------------------
PORTAL_PASSWORD_SALT=replace-with-a-unique-20+-character-salt
PORTAL_SESSION_SECRET=replace-with-a-strong-session-secret
PORTAL_AUTO_SEED_USERS=false

PORTAL_ADMIN_EMAIL=admin@example.org
PORTAL_ADMIN_PASSWORD=replace-with-a-strong-admin-password
PORTAL_ADMIN_PHONE=+256700000001
PORTAL_SUPERADMIN_EMAIL=superadmin@example.org
PORTAL_SUPERADMIN_PASSWORD=replace-with-a-strong-superadmin-password
PORTAL_SUPERADMIN_PHONE=+256700000002

# Optional seeded non-privileged accounts (used only when PORTAL_AUTO_SEED_USERS=true)
PORTAL_STAFF_EMAIL=staff@example.org
PORTAL_STAFF_PASSWORD=replace-with-a-strong-staff-password
PORTAL_STAFF_PHONE=+256700000003
PORTAL_VOLUNTEER_EMAIL=volunteer@example.org
PORTAL_VOLUNTEER_PASSWORD=replace-with-a-strong-volunteer-password
PORTAL_VOLUNTEER_PHONE=+256700000004
PORTAL_SUPERVISOR_EMAIL=supervisor@example.org
PORTAL_SUPERVISOR_PASSWORD=replace-with-a-strong-supervisor-password
PORTAL_SUPERVISOR_PHONE=+256700000005
PORTAL_ME_EMAIL=me@example.org
PORTAL_ME_PASSWORD=replace-with-a-strong-me-password
PORTAL_ME_PHONE=+256700000006

# -----------------------------
# SMTP notifications (optional)
# -----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# -----------------------------
# Google Workspace / Calendar (optional)
# -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=
GOOGLE_WORKSPACE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_ALLOWED_DOMAINS=ozekiread.org
GOOGLE_WORKSPACE_DOMAIN=ozekiread.org

# -----------------------------
# OpenAI / reports (optional)
# -----------------------------
OPENAI_API_KEY=
OPENAI_REPORT_MODEL=gpt-5.2-mini

# -----------------------------
# YouTube (optional)
# -----------------------------
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# =============================================================================
# Production / additional integrations — added 2026-05-06 audit pass.
# Everything below is required for at least one runtime path, but each
# section is optional unless your deploy uses the integration. Every var
# referenced anywhere in src/ should now appear somewhere in this file.
# =============================================================================

# -----------------------------
# Pesapal payments (donation + service fees)
# -----------------------------
# PESAPAL_ENVIRONMENT: "sandbox" or "production". Pick one to match the
# Consumer Key / Secret you registered. PESAPAL_IPN_ID is the UUID Pesapal
# issues after you register your /api/payments/pesapal/ipn URL via the
# IPN-registration flow — see docs/operations/pesapal-ipn-runbook.md.
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_ID=

# -----------------------------
# Finance email routing
# -----------------------------
# FINANCE_EMAIL_FROM is the From: header on invoices/receipts (defaults
# to accounts@ozekiread.org if unset). FINANCE_EMAIL_ALWAYS_CC is a
# comma-separated list always BCC'd on finance mail. FINANCE_ACCOUNTANT_EMAIL
# routes approval-required notifications. FINANCE_FILE_SIGNING_SECRET signs
# downloadable PDF receipt URLs. FINANCE_SYSTEM_ACTOR_ID is the portal
# user id that owns automated finance writes (e.g. Pesapal IPN ledger
# entries) — must point to an existing super-admin row.
FINANCE_EMAIL_FROM=accounts@ozekiread.org
FINANCE_EMAIL_ALWAYS_CC=
FINANCE_ACCOUNTANT_EMAIL=
FINANCE_FILE_SIGNING_SECRET=replace-with-a-strong-32+-char-secret
FINANCE_SYSTEM_ACTOR_ID=1

# -----------------------------
# Programmes / newsletter mail
# -----------------------------
PROGRAMMES_EMAIL_FROM=programmes@ozekiread.org
NEWSLETTER_EMAIL_FROM=newsletter@ozekiread.org
NEWSLETTER_SUBJECT_PREFIX=[Ozeki RBF]
NEWSLETTER_BATCH_SIZE=200
DIGEST_RECIPIENTS=

# -----------------------------
# Google services (additional)
# -----------------------------
# GOOGLE_OAUTH_* are the staff-portal sign-in credentials. They mirror the
# legacy GOOGLE_CLIENT_ID/SECRET pair and the auth code prefers GOOGLE_OAUTH_*
# when both are set. GOOGLE_OAUTH_ALLOWED_DOMAIN is the singular form some
# code paths still read; keep it equal to the first domain in
# GOOGLE_OAUTH_ALLOWED_DOMAINS. GOOGLE_CALENDAR_TIMEZONE controls the
# default tz when scheduling training sessions.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_ALLOWED_DOMAIN=ozekiread.org
GOOGLE_CALENDAR_TIMEZONE=Africa/Kampala
BOOKING_CALENDAR_DURATION_MINUTES=45

# -----------------------------
# Database tuning + safety gates
# -----------------------------
DATABASE_SSL_CA=
DATABASE_CONNECT_TIMEOUT_MS=10000
DATABASE_STARTUP_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DB_SSL_REQUIRE=false
DB_STARTUP_CHECK=true
DB_STARTUP_STRICT=false
DEPLOY_CHECK_STRICT=false
LOG_LEVEL=info

# -----------------------------
# MFA / auth toggles
# -----------------------------
# BYPASS_MFA must be unset (or "false") in production — set to "true"
# only for local dev when you don't want to OTP-verify every login.
BYPASS_MFA=false
SECRET_KEY=replace-with-a-strong-32+-char-secret

# -----------------------------
# Cron / migration tokens
# -----------------------------
# CRON_SECRET / CRON_SECRET_TOKEN / CRON_TOKEN are accepted by background
# job endpoints (sync-recordings, IPN replay, etc) — set them to the same
# value when the route reads either name. MIGRATE_TOKEN gates the
# /api/migrate/* admin routes.
CRON_SECRET=
CRON_SECRET_TOKEN=
CRON_TOKEN=
MIGRATE_TOKEN=

# -----------------------------
# Hostname / split-mode toggles
# -----------------------------
# When ENFORCE_HOST_SPLIT=true, public-site routes refuse to render under
# the admin host (and vice versa). Useful when ADMIN_PORTAL_HOST and
# PUBLIC_SITE_HOST point to different DNS records.
ENFORCE_HOST_SPLIT=false
ENFORCE_ADMIN_HOST_SPLIT=false

# -----------------------------
# Uganda EMIS sync (optional)
# -----------------------------
EMIS_API_BASE_URL=
EMIS_API_TOKEN=

# -----------------------------
# IATI / research / disclosure
# -----------------------------
IATI_REPORTING_ORG_REF=
RESEARCH_DATASET_SALT=replace-with-a-stable-cohort-salt
ZENODO_API_BASE=https://zenodo.org/api
ZENODO_TOKEN=

# -----------------------------
# Vimeo (recorded lessons sync)
# -----------------------------
VIMEO_ACCESS_TOKEN=

# -----------------------------
# Google Search Console reporting (optional)
# -----------------------------
# Provide ONE of: GSC_SERVICE_ACCOUNT_FILE (path), GSC_SERVICE_ACCOUNT_JSON
# (raw JSON), or GSC_SERVICE_ACCOUNT_JSON_B64 (base64). The base64 form is
# easiest for Amplify env vars.
GSC_SERVICE_ACCOUNT_FILE=
GSC_SERVICE_ACCOUNT_JSON=
GSC_SERVICE_ACCOUNT_JSON_B64=
GSC_SITE_URL=https://www.ozekiread.org/

# -----------------------------
# Frontend public vars
# -----------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_S3_MEDIA_BUCKET=
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_DASHBOARD_SIDEBAR_SLOT=
