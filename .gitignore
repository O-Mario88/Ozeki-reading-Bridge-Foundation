.DS_Store

# Env files
.env*
!.env.example

# Node
# node_modules and .next live in *.nosync dirs (iCloud Drive skips those)
# with symlinks at the canonical names — ignore both the symlinks and the
# real dirs. Bare patterns (no trailing slash) are needed to match symlinks.
node_modules
node_modules/
node_modules.nosync/
.next
frontend/node_modules/
frontend/.next/
frontend/out/

# Python
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/staticfiles/
backend/media/

# Build artifacts
.next/
.next*/
*.tsbuildinfo

# Local data snapshots
data/*
!data/.gitkeep
!data/backups/.gitkeep

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-error.log*
database.sqlite
test.pdf
lighthouse-report.json

# Local environment secrets
.env.local
.claude/
